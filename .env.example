# AFFiNE image pins
AFFINE_VERSION=v0.26.3
POSTGRES_VERSION=pg16
REDIS_VERSION=7.4-alpine
MANTICORE_VERSION=10.1.0

# Public URL
AFFINE_SERVER_HOST=docs.zacariahheim.com
AFFINE_SERVER_HTTPS=true
AFFINE_SERVER_EXTERNAL_URL=https://docs.zacariahheim.com
AFFINE_SERVER_SUB_PATH=

# Persistence
DB_DATA_LOCATION=./storage/postgres
UPLOAD_LOCATION=./storage/uploads
CONFIG_LOCATION=./storage/config
MANTICORE_DATA_LOCATION=./storage/manticore

# Database
DB_USERNAME=affine
DB_PASSWORD=replace-with-strong-password
DB_DATABASE=affine

# AFFiNE crypto
# Generate with: openssl rand -base64 48
AFFINE_PRIVATE_KEY=replace-with-affine-private-key

# SMTP
# Source the real values from the existing Authentik service env.
MAILER_HOST=smtp.gmail.com
MAILER_PORT=587
MAILER_USER=zacariahheim@gmail.com
MAILER_PASSWORD=replace-with-authentik-smtp-app-password
MAILER_SENDER=AFFiNE <zacariahheim@gmail.com>
MAILER_IGNORE_TLS=false
